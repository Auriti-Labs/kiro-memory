{
  "name": "totalrecallai",
  "version": "4.0.0",
  "description": "Your AI remembers everything. Persistent cross-session memory for AI coding assistants. Works with Claude Code, Cursor, Windsurf, Cline, and any MCP-compatible editor.",
  "keywords": [
    "totalrecall",
    "ai-memory",
    "claude-code",
    "cursor",
    "windsurf",
    "cline",
    "memory",
    "mcp",
    "model-context-protocol",
    "persistent-memory",
    "vector-search",
    "embeddings",
    "sqlite",
    "typescript",
    "ai-agents",
    "coding-assistant",
    "session-memory",
    "semantic-search",
    "context-management",
    "developer-tools"
  ],
  "author": "Auriti Labs",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Auriti-Labs/totalrecall.git"
  },
  "homepage": "https://github.com/Auriti-Labs/totalrecall#readme",
  "bugs": {
    "url": "https://github.com/Auriti-Labs/totalrecall/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    }
  },
  "files": [
    "dist",
    "plugin",
    "scripts/postinstall.cjs"
  ],
  "bin": {
    "totalrecall": "./plugin/dist/cli/contextkit.js",
    "kiro-memory": "./plugin/dist/cli/contextkit.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "npm run build-and-sync",
    "build": "node scripts/build-plugin.js",
    "typecheck": "npm run typecheck:runtime && npm run typecheck:product && npm run typecheck:ui",
    "typecheck:runtime": "NODE_OPTIONS=--max-old-space-size=8192 tsc -p tsconfig.runtime.json --noEmit",
    "typecheck:product": "NODE_OPTIONS=--max-old-space-size=8192 tsc -p tsconfig.product.json --noEmit",
    "typecheck:ui": "NODE_OPTIONS=--max-old-space-size=8192 tsc -p tsconfig.ui.json --noEmit",
    "typecheck:core": "npm run typecheck:runtime && npm run typecheck:product",
    "build-and-sync": "npm run build && npm run sync-kiro && npm run worker:restart",
    "sync-kiro": "node scripts/sync-kiro.cjs",
    "sync-kiro:force": "node scripts/sync-kiro.cjs --force",
    "worker:start": "node plugin/dist/cli/contextkit.js worker:start",
    "worker:stop": "node plugin/dist/cli/contextkit.js worker:stop",
    "worker:restart": "node plugin/dist/cli/contextkit.js worker:restart",
    "worker:status": "node plugin/dist/cli/contextkit.js worker:status",
    "worker:logs": "sh -c 'tail -n 50 \"${TOTALRECALL_DATA_DIR:-$HOME/.totalrecall}/logs/totalrecall-$(date +%Y-%m-%d).log\"'",
    "worker:tail": "sh -c 'tail -f -n 50 \"${TOTALRECALL_DATA_DIR:-$HOME/.totalrecall}/logs/totalrecall-$(date +%Y-%m-%d).log\"'",
    "queue": "bun scripts/check-pending-queue.ts",
    "queue:process": "bun scripts/check-pending-queue.ts --process",
    "queue:clear": "bun scripts/clear-failed-queue.ts --all --force",
    "context:regenerate": "bun scripts/regenerate-context.ts",
    "context:dry-run": "bun scripts/regenerate-context.ts --dry-run",
    "test": "bun test",
    "test:sqlite": "bun test tests/sqlite/",
    "test:agents": "bun test tests/worker/agents/",
    "test:search": "bun test tests/worker/search/",
    "test:context": "bun test tests/context/",
    "test:infra": "bun test tests/infrastructure/",
    "test:server": "bun test tests/server/",
    "install:kiro": "bash scripts/install-kiro.sh",
    "postinstall": "node scripts/postinstall.cjs",
    "prepublishOnly": "npm run build",
    "release": "np",
    "release:patch": "np patch --no-cleanup",
    "release:minor": "np minor --no-cleanup",
    "release:major": "np major --no-cleanup"
  },
  "np": {
    "yarn": false,
    "contents": ".",
    "testScript": "test",
    "2fa": false
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ansi-to-html": "^0.7.2",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "cors": "^2.8.5",
    "dompurify": "^3.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "glob": "^11.0.3",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "lucide-react": "^0.574.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.8.2",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.8.0",
    "fastembed": "^2.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "bun-types": "^1.0.0",
    "esbuild": "^0.27.2",
    "np": "^11.0.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.20.6",
    "typescript": "^5.3.0"
  }
}
