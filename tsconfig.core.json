{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "lib": ["ES2022"],
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": true
  },
  "include": [
    "src/cli/**/*",
    "src/db/**/*",
    "src/hooks/**/*",
    "src/index.ts",
    "src/plugins/**/*",
    "src/sdk/**/*",
    "src/servers/**/*",
    "src/services/**/*",
    "src/shared/**/*",
    "src/types/**/*",
    "src/utils/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "plugin",
    "tests",
    "src/ui/**/*"
  ]
}
